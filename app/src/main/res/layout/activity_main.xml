<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Connection Bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_connection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="12dp">

            <View
                android:id="@+id/status_dot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/circle" />

            <TextView
                android:id="@+id/tv_device_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/not_connected"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_connect"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="@string/connect" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Demo Mode Toggle -->
    <com.google.android.material.materialswitch.MaterialSwitch
        android:id="@+id/switch_demo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Demo Mode"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_connection" />

    <!-- State Display -->
    <TextView
        android:id="@+id/tv_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="STOP"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/switch_demo" />

    <!-- D-Pad -->
    <GridLayout
        android:id="@+id/grid_dpad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="3"
        app:layout_constraintBottom_toTopOf="@id/card_controls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_state">

        <Space
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_column="0"
            android:layout_row="0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_forward"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_column="1"
            android:layout_margin="4dp"
            android:layout_row="0"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="\u25B2"
            android:textSize="28sp"
            app:cornerRadius="16dp" />

        <Space
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_column="2"
            android:layout_row="0" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_left"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_column="0"
            android:layout_margin="4dp"
            android:layout_row="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="\u25C0"
            android:textSize="28sp"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_stop"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_column="1"
            android:layout_margin="4dp"
            android:layout_row="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="STOP"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@color/stop_red"
            app:cornerRadius="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_right"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_column="2"
            android:layout_margin="4dp"
            android:layout_row="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="\u25B6"
            android:textSize="28sp"
            app:cornerRadius="16dp" />

        <Space
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_column="0"
            android:layout_row="2" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_backward"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_column="1"
            android:layout_margin="4dp"
            android:layout_row="2"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="\u25BC"
            android:textSize="28sp"
            app:cornerRadius="16dp" />

        <Space
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_column="2"
            android:layout_row="2" />

    </GridLayout>

    <!-- Speed Controls Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Row 1: Speed + Turn Speed -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Speed -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="wrap_content"
                        android:text="Speed"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_speed_down"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="40dp"
                        android:layout_height="36dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:text="\u2212"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tv_speed_display"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="75"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_speed_up"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="40dp"
                        android:layout_height="36dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:text="+"
                        android:textSize="18sp" />

                </LinearLayout>

                <!-- Turn Speed -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="wrap_content"
                        android:text="Turn"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_turn_speed_down"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="40dp"
                        android:layout_height="36dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:text="\u2212"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tv_turn_speed_display"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="100"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_turn_speed_up"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="40dp"
                        android:layout_height="36dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:text="+"
                        android:textSize="18sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Row 2: Increment + Turn Increment -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Increment -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="wrap_content"
                        android:text="Step"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_increment_down"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="40dp"
                        android:layout_height="36dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:text="\u2212"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tv_increment_display"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="10"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_increment_up"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="40dp"
                        android:layout_height="36dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:text="+"
                        android:textSize="18sp" />

                </LinearLayout>

                <!-- Turn Increment -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="52dp"
                        android:layout_height="wrap_content"
                        android:text="T.Step"
                        android:textSize="12sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_turn_increment_down"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="40dp"
                        android:layout_height="36dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:text="\u2212"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tv_turn_increment_display"
                        android:layout_width="36dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="10"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_turn_increment_up"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="40dp"
                        android:layout_height="36dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:padding="0dp"
                        android:text="+"
                        android:textSize="18sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
